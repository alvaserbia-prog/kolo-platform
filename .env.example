# ─────────────────────────────────────────────────────────────────────────────
# KOLO Platforma — primer env varijabli. Kopiraj u `.env` i popuni vrednosti.
# NIKAD ne commit-uj pravi `.env` sa tajnama u repozitorijum.
# ─────────────────────────────────────────────────────────────────────────────

# Baza i autentikacija
DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
ADMIN_EMAIL=

# Cron (Vercel) i režim održavanja
CRON_SECRET=
MAINTENANCE_MODE=false
# Rani pristup ("early access"): dok je MAINTENANCE_MODE=true, osoba koja zna ovaj
# kod može na /rani-pristup da otključa prijavu i registraciju (za rane prihvatioce).
# Ostavi prazno da bi rani pristup bio isključen. Promena koda poništava ranije izdate pristupe.
RANI_PRISTUP_KOD=

# OAuth (Google) — opciono
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend) — opciono
RESEND_API_KEY=
RESEND_FROM=

# Telegram / analitika — opciono
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NEXT_PUBLIC_CLARITY_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Kartično plaćanje donacija (NestPay: Banca Intesa / OTP banka Srbija)
#
# Obe banke koriste isti NestPay gateway — razlika je samo u vrednostima.
# PLACANJE_AKTIVNO mora biti "true" i izabrani provajder mora imati popunjene
# CLIENT_ID i STORE_KEY da bi kartično plaćanje radilo. Dok je prazno → na
# stranici donacija radi samo klasična uplata na račun.
#
# VAŽNO: STORE_KEY je tajna — drži je samo u env-u (Vercel Project Settings),
# nikad u kodu/repou. Test (sandbox) vrednosti dobijaš uz test nalog banke;
# produkcijske tek po odobrenom trgovačkom nalogu.
# ─────────────────────────────────────────────────────────────────────────────
PLACANJE_AKTIVNO=false
PLACANJE_PROVAJDER=INTESA          # INTESA | OTP

# Banca Intesa (NestPay) — test/sandbox URL banke
NESTPAY_INTESA_GATEWAY_URL=
NESTPAY_INTESA_CLIENT_ID=
NESTPAY_INTESA_STORE_KEY=
NESTPAY_INTESA_STORE_TYPE=3d_pay_hosting

# OTP banka Srbija (NestPay)
NESTPAY_OTP_GATEWAY_URL=
NESTPAY_OTP_CLIENT_ID=
NESTPAY_OTP_STORE_KEY=
NESTPAY_OTP_STORE_TYPE=3d_pay_hosting
