# ─── KOLO Platforma — primer env varijabli ─────────────────────────────────
# Kopiraj u .env.local (lokalni rad) i popuni vrednosti.
# Na Vercel-u se postavljaju u Project Settings → Environment Variables,
# odvojeno po okruženju (Production / Preview / Custom Environment "test").
# Svi .env* fajlovi su u .gitignore — NIKAD ne commituj prave vrednosti.

# ─── Baza (Postgres / Neon) ────────────────────────────────────────────────
# Različita vrednost po okruženju:
#   lokalno     → lokalni Postgres ili Neon dev branch
#   test        → kolo-peach (Neon) — postavljeno na Vercel Preview/test scope
#   produkcija  → produkcijska Neon baza — Vercel Production scope
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth ───────────────────────────────────────────────────────────────
# NEXTAUTH_URL = pun URL okruženja (npr. https://test.ekolo.rs / https://ekolo.rs)
# NEXTAUTH_SECRET = generiši sa: openssl rand -base64 32 (različit po okruženju)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Google OAuth (opciono) ─────────────────────────────────────────────────
# Callback URL u Google konzoli mora odgovarati svakom okruženju.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (Resend) — reset lozinke, admin alerti (opciono) ─────────────────
RESEND_API_KEY=""
RESEND_FROM="KOLO <noreply@ekolo.rs>"
ADMIN_EMAIL=""

# ─── Telegram admin alerti (opciono) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ─── Cron zaštita ───────────────────────────────────────────────────────────
# Vercel cron rute proveravaju ovaj secret u Authorization header-u.
CRON_SECRET=""

# ─── Analytics (opciono) ────────────────────────────────────────────────────
NEXT_PUBLIC_CLARITY_ID=""

# ─── Samo za RUČNE produkcijske migracije (lokalno, .env.production.local) ──
# Alternativa: stavi DATABASE_URL u .env.production.local umesto ovoga.
# PROD_DATABASE_URL="postgresql://...produkcija..."
