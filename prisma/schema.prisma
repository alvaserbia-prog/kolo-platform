generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enumi ───────────────────────────────────────────────────────────────────

enum WalletType {
  USER
  KRUG
  PROTOKOL
}

enum KrugStatus {
  ACTIVE
  SUSPENDED
}

enum KrugOsnivanjeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PristupnicaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectType {
  PRIKUPLJANJE
  REDISTRIBUCIJA
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
}

// Smer oglasa na Pijaci: PONUDA = oglašivač nudi dobro/uslugu (klasičan oglas),
// POTRAZNJA = oglašivač traži nekoga da uradi/napravi nešto („traži se").
// Kod POTRAZNJA budžet se uvek dogovara (cenaTip = DOGOVOR, bez iznosa).
enum TipOglasa {
  PONUDA
  POTRAZNJA
}

// Varijanta cene na oglasu Pijace (bira je oglašivač).
enum CenaTip {
  FIKSNA  // jedan iznos
  RASPON  // od–do
  DOGOVOR // bez iznosa, „po dogovoru"
}

enum TransactionType {
  TRANSFER
  EMISIJA_VERIFIKACIJA
  EMISIJA_NADZOR
  EMISIJA_DONACIJA
  EMISIJA_POKROVITELJ
  EMISIJA_KRUG_OSNIVANJE
  EMISIJA_KRUG_BONUS
  EMISIJA_PROGRAM
  UPIS_ZRNO
  OTPIS_ZRNO
  EMISIJA_OSNIVACKI
}

enum TipKorisnika {
  REGULARNI
  NOSILAC_ZRNA
  NEVERIFIKOVAN
}

// Operativna ovlašćenja (admin osa), nezavisna od članskog tipa (TipKorisnika).
// NONE = običan član; ADMIN = svakodnevna operativa; SUPERADMIN = sve + opasne
// radnje + verifikuje prve ljude (koren lanca jemstva).
enum AdminNivo {
  NONE
  ADMIN
  SUPERADMIN
}

enum ZrnoZahtevStatus {
  PENDING
  EXECUTED
  CANCELLED
}

enum ZrnoStatusAkcija {
  ZAKLJUCAJ
  OTKLJUCAJ
}

enum PredlogStatus {
  ACTIVE
  CLOSED
}

// Stanje izvršenja usvojene odluke Gornjeg Kola (čl. 17, 18)
enum IzvrsenjeStatus {
  ZA_IZVRSENJE      // usvojeno, čeka izvršenje od strane Fondacije
  IZVRSENO          // Fondacija izvršila odluku
  VETO_OBUSTAVLJENO // izvršenje obustavljeno zaštitnim vetom (čl. 18, 48)
}

// Vrsta predloga: obavezujuća odluka ili neobavezujuća dinarska preporuka (čl. 20)
enum PredlogVrsta {
  ODLUKA
  DINARSKA_PREPORUKA
}

// Obrazložen odgovor UO na usvojenu dinarsku preporuku (čl. 20)
enum UoOdgovor {
  PRIHVACENO
  ODBIJENO
}

enum ProgramType {
  PED
  PODRSKA_MAJKAMA
  PODRSKA_STARIJIMA
  POSEBNA_BRIGA
  SKOLOVANJE
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum PotvrdaStatus {
  CEKA
  POTVRDJENO
  ODBIJENO
}

enum EvidencijaStatus {
  PENDING
  APPROVED
  REJECTED
  EMITTED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  EXCLUDED
}

enum DonationStatus {
  PENDING
  CONFIRMED
}

enum VrstaDonacije {
  NOVAC
  ROBA
  USLUGE
}

enum PokroviteljPrijavaStatus {
  CEKA_POTPIS
  POTPISANA
  POTVRDJENA
  ODBIJENA
}

enum OglasStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum OglasSource {
  FONDACIJA
  KRUG
  PROJEKAT
}

enum OglasPrijavaStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Modeli ───────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  email              String?   @unique
  passwordHash       String?
  oauthProvider      String?
  oauthId            String?
  oauthPending       Boolean   @default(false)
  pseudonim          String    @unique
  status             UserStatus @default(ACTIVE)
  suspendedAt        DateTime?
  suspendedReason    String?
  verified           Boolean   @default(false)
  verifiedAt         DateTime?
  tipKorisnika           TipKorisnika @default(NEVERIFIKOVAN)
  admin                  AdminNivo    @default(NONE)
  // Oznaka početnog nosioca ZRNA (osnivač). Zaseban marker pored tipKorisnika —
  // status NOSILAC_ZRNA može steći i običan korisnik upisom ZRNA, pa nije pouzdan
  // pokazatelj osnivača. Osnivač NE sme da verifikuje drugog osnivača (anti-malverzacija).
  jeOsnivac              Boolean      @default(false)
  indeksStvarnosti       Int          @default(0)
  slotoviPotroseni       Int          @default(0)
  pocetnaEmisijaIzvrsena Boolean      @default(false)
  pseudonimChangedAt DateTime?
  // "Viđeno" vremena za sidebar badge-eve: badge broji samo stavke novije od ovog
  // trenutka. Postavlja se kad korisnik otvori odgovarajući tab → badge ide na 0.
  vidjenoNovcanikAt  DateTime?
  vidjenoPijacaAt    DateTime?
  memberHash         String    @unique
  location           String?
  telefon            String?
  avatar             String?
  // Izabrani jezik korisnika (next-intl locale): "sr" | "sr-Cyrl" | "en" | "hu".
  // Koristi se za jezik notifikacija/email-ova i podrazumevani prikaz po prijavi.
  jezik              String    @default("sr")
  deaktiviranAt      DateTime?
  pristankiPolitike  PolitikaPrihvatanje[]
  pristankiPravilnika PravilnikPrihvatanje[]
  osnivacZapis        Osnivac?                   @relation("Osnivac")
  kreiraniTroskovi    FondacijaTrosak[]          @relation("KreiraoTrosak")
  wallet             Wallet?
  podaci                 UserPodaci?
  donations              DonationRecord[]
  kreiraniPokrovitelji   Pokrovitelj[]              @relation("AdminKreiraoP")
  vlasnikPokrovitelja    Pokrovitelj[]              @relation("VlasnikP")
  evidentiraniDoprinosi  PokroviteljDoprinos[]      @relation("EvidentiraoDoprinos")
  pokroviteljBonusi      PokroviteljBonusEmisija[]  @relation("PrimalacBonusa")
  kreiraniOglasi         DoprinosOglas[]            @relation("KreiraniOglasi")
  oglasPrijave           OglasPrijava[]             @relation("OglasPrijave")
  oglasEvidencije        OglasEvidencija[]          @relation("OglasEvidencije")
  listings               MarketplaceListing[]       @relation("SellerListings")
  purchases              MarketplaceListing[]       @relation("BuyerListings")
  krugClanstva   KrugClanstvo[]
  pristupnice            KrugPristupnica[]
  osnivanjeZahtevi       KrugOsnivanjeZahtev[] @relation("Inicijator")
  programEnrollments     ProgramEnrollment[]
  programPotvrde         ProgramPotvrda[]           @relation("VerifikatorPotvrda")
  zrnoStanje             ZrnoStanje?
  zrnoUpisZahtevi        ZrnoUpisZahtev[]
  zrnoOtpisZahtevi       ZrnoOtpisZahtev[]
  zrnoStatusZahtevi      ZrnoStatusZahtev[]
  delegiraoKome          ZrnoDelegacija?            @relation("Delegator")
  delegatZa              ZrnoDelegacija[]           @relation("Delegat")
  zakazanZaDelegata      ZrnoDelegacija[]           @relation("ZakazaniDelegat")
  kreiraniPredlozi       GlasanjePredlog[]
  glasovi                GlasanjeGlas[]
  auditLogs              AuditLog[]                 @relation("AdminActions")
  notifikacije           Notifikacija[]
  pushPretplate          PushPretplata[]
  konverzacije1          Konverzacija[]             @relation("KonvUser1")
  konverzacije2          Konverzacija[]             @relation("KonvUser2")
  porukePoslate          Poruka[]                   @relation("PorukePostavljene")
  prigovori              PrigovorNaOdluku[]
  blogObjave             BlogPost[]                 @relation("BlogAutor")
  chatPoruke             ChatMessage[]              @relation("ChatPoruke")
  passwordResetTokens    PasswordResetToken[]
  verifikacijeKojeSamObavio       VerifikacionaVeza[] @relation("Verifikator")
  verifikacijeKojeSuMeVerifikovale VerifikacionaVeza[] @relation("Verifikovani")
  nadzori                         VerifikacionaVeza[] @relation("Nadzornik")
  verifikacijaTokeni              VerifikacijaToken[]
  zabranjenaZona                  VerifikacionaZona[] @relation("ZonaVlasnik")
  uTudjimZonama                   VerifikacionaZona[] @relation("ZonaZabranjeni")
  zahteviZaJemstvo                ZahtevZaJemstvo[]
  pokroviteljPrijave              PokroviteljPrijava[]       @relation("PodnosilacPrijave")
  prijavljeniBagovi               Bug[]                      @relation("PrijaviocBaga")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model UserPodaci {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  punoIme   String?
  opis      String?
  updatedAt DateTime @updatedAt

  // Vidljivost profila
  prikaziLokaciju      Boolean @default(true)
  prikaziOpis          Boolean @default(false)
  prikaziPunoIme       Boolean @default(false)
  prikaziTelefon       Boolean @default(false)
  prikaziBilans        Boolean @default(true)
  prikaziZrno          Boolean @default(true)
  prikaziRangDonacija  Boolean @default(true)
  prikaziOglase        Boolean @default(true)
}

model Wallet {
  id          String        @id @default(uuid())
  userId      String?       @unique
  user        User?         @relation(fields: [userId], references: [id])
  krugId String?       @unique
  krug   Krug?    @relation("KrugWallet", fields: [krugId], references: [id])
  balance     Int           @default(0)
  type        WalletType
  outgoingTx  Transaction[] @relation("FromWallet")
  incomingTx  Transaction[] @relation("ToWallet")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Transaction {
  id           String          @id @default(uuid())
  fromWalletId String?
  fromWallet   Wallet?         @relation("FromWallet", fields: [fromWalletId], references: [id])
  toWalletId   String
  toWallet     Wallet          @relation("ToWallet", fields: [toWalletId], references: [id])
  amount       Int
  type         TransactionType
  description  String?
  createdAt    DateTime        @default(now())
}

model Krug {
  id             String          @id @default(uuid())
  name           String          @unique
  description    String?
  location       String?
  status         KrugStatus @default(ACTIVE)
  wallet         Wallet?         @relation("KrugWallet")
  memberships    KrugClanstvo[]
  pristupnice    KrugPristupnica[]
  projects       KrugProjekat[]
  bonusLogs      KrugBonusLog[]
  doprinosOglasi DoprinosOglas[] @relation("KrugOglasi")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model KrugClanstvo {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  krugId String
  krug   Krug @relation(fields: [krugId], references: [id])
  isAdmin     Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  @@index([userId, leftAt])
  @@index([krugId, leftAt])
}

model KrugOsnivanjeZahtev {
  id              String                   @id @default(uuid())
  name            String
  description     String?
  location        String?
  inicijatorId    String
  inicijator      User                     @relation("Inicijator", fields: [inicijatorId], references: [id])
  osnivaci        String[]
  status          KrugOsnivanjeStatus @default(PENDING)
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime                 @default(now())
}

model KrugPristupnica {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  krugId String
  krug   Krug         @relation(fields: [krugId], references: [id])
  status      PristupnicaStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  @@unique([userId, krugId])
}

model KrugProjekat {
  id          String      @id @default(uuid())
  krugId String
  krug   Krug   @relation(fields: [krugId], references: [id])
  type        ProjectType
  title       String
  description String
  status      String      @default("ACTIVE")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model KrugBonusLog {
  id          String    @id @default(uuid())
  krugId String
  krug   Krug @relation(fields: [krugId], references: [id])
  threshold   Int
  amount      Int
  createdAt   DateTime  @default(now())

  // Svaki prag rasta kruga se isplaćuje tačno jednom (race-safe rezervacija praga).
  @@unique([krugId, threshold])
}

model MarketplaceListing {
  id          String        @id @default(uuid())
  sellerId    String
  seller      User          @relation("SellerListings", fields: [sellerId], references: [id])
  buyerId     String?
  buyer       User?         @relation("BuyerListings", fields: [buyerId], references: [id])
  // Smer oglasa (ponuda vs potražnja). Kod POTRAZNJA je cenaTip uvek DOGOVOR.
  tip         TipOglasa     @default(PONUDA)
  title       String
  description String
  // Cena ima tri varijante (bira ih oglašivač):
  //  - FIKSNA  → jedan iznos u `price` (cenaDo = null)
  //  - RASPON  → `price` = donja granica, `cenaDo` = gornja granica
  //  - DOGOVOR → bez iznosa („po dogovoru"); price = cenaDo = null
  // `price` (donja granica/fiksna cena) ostaje numerička osnova za sortiranje i min/max filter.
  cenaTip     CenaTip       @default(FIKSNA)
  price       Int?
  cenaDo      Int?
  // Opciona jedinica mere za cenu (kom, kg, g, l, ml, m, pak) i stanje na zalihama.
  // Oba su informativna — ne utiču na tok kupovine (oglas se i dalje kupuje u celosti).
  jedinica    String?
  kolicina    Int?
  category    String
  images      String[]
  location    String?
  phone       String?
  status      ListingStatus @default(ACTIVE)
  soldAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, category, createdAt])
  @@index([status, tip, createdAt])
}

model ProtokolProgram {
  type        ProgramType @id
  isActive    Boolean     @default(false)
  activatedAt DateTime?
  updatedAt   DateTime    @updatedAt
}

model ProgramEnrollment {
  id                    String               @id @default(uuid())
  userId                String
  user                  User                 @relation(fields: [userId], references: [id])
  type                  ProgramType
  status                EnrollmentStatus     @default(PENDING)
  metadata              Json?
  dailyAmount           Int?
  // Izričit pristanak da verifikatori budu zamoljeni da potvrde ispunjenost uslova
  // (Pravilnik o programima podrške čl. 4 — pravni osnov obrade je pristanak).
  pristanakVerifikatori Boolean              @default(false)
  approvedById          String?
  approvedAt            DateTime?
  rejectionReason       String?
  nextReverifikacija    DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  potvrde               ProgramPotvrda[]

  @@unique([userId, type])
  @@index([status, type])
}

// Potvrda verifikatora da prijavljeni korisnik ispunjava uslov socijalnog programa.
// Verifikator potvrđuje pod punom odgovornošću, na osnovu ličnog poznavanja osobe —
// NEMA uvid u osetljive prijavljene podatke (datumi rođenja dece, rešenje o
// invaliditetu i sl.), koji ostaju dostupni samo licu koje obrađuje prijavu (čl. 4).
// Odbijanje zahteva obrazloženje.
model ProgramPotvrda {
  id            String            @id @default(uuid())
  enrollmentId  String
  enrollment    ProgramEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  verifikatorId String
  verifikator   User              @relation("VerifikatorPotvrda", fields: [verifikatorId], references: [id])
  status        PotvrdaStatus     @default(CEKA)
  obrazlozenje  String?
  odgovorAt     DateTime?
  createdAt     DateTime          @default(now())

  @@unique([enrollmentId, verifikatorId])
  @@index([verifikatorId, status])
}

model DailyEmissionSummary {
  id             String   @id @default(uuid())
  date           DateTime @db.Date @unique
  opticaj        Int
  limit          Int
  totalRequested Int
  totalEmitted   Int
  koeficijent    Decimal  @db.Decimal(10, 6)
  breakdown      Json
  createdAt      DateTime @default(now())
}

// ─── Program Doprinosa Zajedničkom Dobru — Oglasi ─────────────────────────────

model DoprinosOglas {
  id             String        @id @default(uuid())
  title          String
  description    String
  source         OglasSource
  predlozeniPoen Int           // predloženi POEN za potpuno izvršenje (čl. 5/6) — težinski koeficijent, nije garantovan iznos
  obrazlozenje   String?       // obrazloženje predloženog POEN-a (čl. 6)
  saOdobravanjem Boolean       @default(false) // čl. 14 — prijava primljena tek po izričitom odobrenju plana izvršenja
  positions      Int           @default(1)
  deadline       DateTime?     // rok za prijavu
  status         OglasStatus   @default(ACTIVE)
  createdById    String
  createdBy      User          @relation("KreiraniOglasi", fields: [createdById], references: [id])
  krugId    String?
  krug      Krug?    @relation("KrugOglasi", fields: [krugId], references: [id])
  prijave        OglasPrijava[]
  evidencije     OglasEvidencija[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, createdAt(sort: Desc)])
}

model OglasPrijava {
  id              String             @id @default(uuid())
  oglasId         String
  oglas           DoprinosOglas      @relation(fields: [oglasId], references: [id])
  userId          String
  user            User               @relation("OglasPrijave", fields: [userId], references: [id])
  planIzvrsenja   String?            // plan izvršenja (čl. 11) — obavezan za zadatke „sa odobravanjem"
  status          OglasPrijavaStatus @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  evidencije      OglasEvidencija[]
  createdAt       DateTime           @default(now())

  @@unique([oglasId, userId])
  @@index([status, oglasId])
}

model OglasEvidencija {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation("OglasEvidencije", fields: [userId], references: [id])
  oglasId      String
  oglas        DoprinosOglas      @relation(fields: [oglasId], references: [id])
  prijavaId    String
  prijava      OglasPrijava       @relation(fields: [prijavaId], references: [id])
  date         DateTime           @db.Date  // dan na koji se odnosi izvršenje
  predlozeniPoen Int              // predloženi POEN za ovo dnevno izvršenje (čl. 18) — težina u raspodeli
  amount       Int                @default(0) // evidentirani POEN nakon noćne raspodele (čl. 24); 0 dok nije obračunato
  dokaz        String?            // link/opis dokaza izvršenja (čl. 18)
  description  String
  status       EvidencijaStatus   @default(PENDING)  // PENDING→APPROVED (potvrđeno, ulazi u raspodelu)→EMITTED / REJECTED
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime           @default(now())

  @@unique([userId, oglasId, date])
  @@index([date, status])
  @@index([status])
}

// ─── ZRNO sistem ─────────────────────────────────────────────────────────────

model ZrnoTrziste {
  id          String    @id @default("singleton")
  isActive    Boolean   @default(false)
  activatedAt DateTime?
  updatedAt   DateTime  @updatedAt
}

model ZrnoStanje {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  slobodno  Int      @default(0)
  aktivno   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model ZrnoUpisZahtev {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  poenIznos    Int
  date         DateTime         @db.Date
  status       ZrnoZahtevStatus @default(PENDING)
  zrnaKupljeno Int?
  poenPlaceno  Int?
  createdAt    DateTime         @default(now())

  @@unique([userId, date])
  @@index([date, status])
}

model ZrnoOtpisZahtev {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  kolicina     Int
  date         DateTime         @db.Date
  status       ZrnoZahtevStatus @default(PENDING)
  poenDobijeno Int?
  createdAt    DateTime         @default(now())

  @@unique([userId, date])
  @@index([date, status])
}

model ZrnoStatusZahtev {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  kolicina  Int
  akcija    ZrnoStatusAkcija
  date      DateTime         @db.Date
  status    ZrnoZahtevStatus @default(PENDING)
  createdAt DateTime         @default(now())

  @@index([date, status])
}

model ZrnoDailyRate {
  date           DateTime @db.Date @unique
  kurs           Decimal  @db.Decimal(20, 2)
  protokolMinus  Int
  zrnaUProtokolu Int
  createdAt      DateTime @default(now())
}

model ZrnoDelegacija {
  id                String   @id @default(uuid())
  delegatorId       String   @unique
  delegator         User     @relation("Delegator", fields: [delegatorId], references: [id])
  delegatId         String?
  delegat           User?    @relation("Delegat", fields: [delegatId], references: [id])
  zakazaniDelegatId String?
  zakazaniDelegat   User?    @relation("ZakazaniDelegat", fields: [zakazaniDelegatId], references: [id])
  imaZakazano       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── Glasanje ─────────────────────────────────────────────────────────────────

model GlasanjePredlog {
  id              String        @id @default(uuid())
  title           String
  description     String
  authorId        String
  author          User          @relation(fields: [authorId], references: [id])
  vrsta           PredlogVrsta  @default(ODLUKA) // odluka (obavezujuća) ili dinarska preporuka (čl. 20)
  glasanjePocetak DateTime      // ponoć narednog obračunskog perioda (čl. 11)
  deadline        DateTime      // kraj glasanja = kraj tog perioda
  status          PredlogStatus @default(ACTIVE)
  ishodUsvojen    Boolean?      // utvrđen po zatvaranju, prosta većina (čl. 8, 9, 13)
  zaZbir          Int?          // zbir glasačke moći „za" u trenutku zatvaranja
  protivZbir      Int?          // zbir glasačke moći „protiv" u trenutku zatvaranja
  izvrsenjeStatus IzvrsenjeStatus? // postavlja se na ZA_IZVRSENJE kad je odluka usvojena (čl. 17)
  vetoObrazlozenje String?      // obavezno obrazloženje zaštitnog veta (čl. 18)
  izvrsenoAt      DateTime?
  vetoAt          DateTime?
  uoOdgovor       UoOdgovor?    // obrazložen odgovor UO na usvojenu preporuku (čl. 20)
  uoObrazlozenje  String?
  uoOdgovorAt     DateTime?
  glasovi         GlasanjeGlas[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model GlasanjeGlas {
  id              String          @id @default(uuid())
  predlogId       String
  predlog         GlasanjePredlog @relation(fields: [predlogId], references: [id])
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  za              Boolean
  glasackaGlasova Int
  createdAt       DateTime        @default(now())

  @@unique([predlogId, userId])
  @@index([predlogId])
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String
  admin     User     @relation("AdminActions", fields: [adminId], references: [id])
  akcija    String
  targetId  String?
  detalji   String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model DonationRecord {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  amountRSD       Decimal        @db.Decimal(12, 2)
  cumulativeRSD   Decimal        @db.Decimal(12, 2)
  level           Int
  poenEmitted     Int
  status          DonationStatus @default(PENDING)
  referenceNumber String?
  confirmedAt     DateTime?
  confirmedById   String?
  createdAt       DateTime       @default(now())

  // Kartično plaćanje (NestPay: Banca Intesa / OTP). RUCNO = klasična uplata
  // na račun koju admin ručno potvrđuje. KARTICA = naplata preko gateway-a.
  nacinUplate     String         @default("RUCNO")
  provajder       String?
  oid             String?        @unique
  bankRef         String?

  // Javna vs anonimna donacija (Pravilnik o pokroviteljstvu i donacijama, čl. 3,
  // 5a). Javna donacija (true) → ime i prezime donatora vidljivi u listi donacija
  // i evidentira se POEN. Anonimna (false) → bez imena i BEZ POEN-a.
  javno           Boolean        @default(true)

  // Ime i prezime donatora SNIMLJENO u trenutku evidentiranja javne donacije —
  // trajan zapis (kao i podaci o uplati), nezavisan od kasnijih izmena profila.
  // Lista donacija prikazuje upravo ovo polje. Null = anonimna ili istorijska
  // donacija (pre uvođenja pravila) → ne prikazuje se u listi.
  donatorIme      String?

  @@index([status, createdAt])
}

// ─── Pokrovitelji ─────────────────────────────────────────────────────────────

model Pokrovitelj {
  id             String      @id @default(uuid())
  naziv          String
  pib            String      @unique
  adresa         String?
  kontaktEmail   String?
  kontaktTelefon String?
  vlasnikId      String
  vlasnik        User        @relation("VlasnikP", fields: [vlasnikId], references: [id])
  kreiraoId      String
  kreirao        User        @relation("AdminKreiraoP", fields: [kreiraoId], references: [id])
  rsdKumulativ   Decimal     @default(0) @db.Decimal(12, 2)
  trenutniNivo   Int         @default(0)
  status         String      @default("ACTIVE")  // ACTIVE | SUSPENDED
  doprinosi      PokroviteljDoprinos[]
  bonusiEmisije  PokroviteljBonusEmisija[]
  prijave        PokroviteljPrijava[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([vlasnikId])
  @@index([status])
}

// Prijava pokroviteljstva (čl. 7–9) — verifikovani korisnik pokreće evidenciju
// doprinosa pravnog lica; platforma generiše ugovor; po potvrdi Fondacije emituje
// se bonus POEN prema nivoima (čl. 10).
model PokroviteljPrijava {
  id             String                   @id @default(uuid())
  podnosilacId   String
  podnosilac     User                     @relation("PodnosilacPrijave", fields: [podnosilacId], references: [id])
  naziv          String
  pib            String
  vrstaDonacije  VrstaDonacije
  vrednostRsd    Decimal                  @db.Decimal(12, 2)
  cenovnikSlika  String?
  ugovorTekst    String
  status         PokroviteljPrijavaStatus @default(CEKA_POTPIS)
  potpisanoAt    DateTime?
  pokroviteljId  String?
  pokrovitelj    Pokrovitelj?             @relation(fields: [pokroviteljId], references: [id])
  potvrdioId     String?
  potvrdjenoAt   DateTime?
  odbijenoRazlog String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([podnosilacId])
  @@index([status])
}

model PokroviteljDoprinos {
  id            String                  @id @default(uuid())
  pokroviteljId String
  pokrovitelj   Pokrovitelj             @relation(fields: [pokroviteljId], references: [id])
  rsdIznos      Decimal                 @db.Decimal(12, 2)
  tip           VrstaDonacije
  evidentiraoId String
  evidentirao   User                    @relation("EvidentiraoDoprinos", fields: [evidentiraoId], references: [id])
  napomena      String?
  createdAt     DateTime                @default(now())

  @@index([pokroviteljId, createdAt(sort: Desc)])
}

model PokroviteljBonusEmisija {
  id            String      @id @default(uuid())
  pokroviteljId String
  pokrovitelj   Pokrovitelj @relation(fields: [pokroviteljId], references: [id])
  vlasnikId     String
  vlasnik       User        @relation("PrimalacBonusa", fields: [vlasnikId], references: [id])
  nivo          Int
  bonusPoen     Int
  transactionId String?
  createdAt     DateTime    @default(now())

  @@index([pokroviteljId])
  @@index([vlasnikId])
}

model Notifikacija {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tip       String
  naslov    String
  tekst     String
  procitana Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, procitana])
  @@index([userId, createdAt(sort: Desc)])
}

// Web Push pretplata uređaja (browser Push API). Jedan korisnik može imati više
// pretplata (više uređaja/browsera). `endpoint` je jedinstven po pretplati;
// `p256dh`/`auth` su ključevi za enkripciju payload-a (VAPID). Briše se kaskadno
// pri brisanju naloga, a i kad push servis vrati 404/410 (pretplata istekla).
model PushPretplata {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Konverzacija {
  id            String   @id @default(uuid())
  user1Id       String
  user2Id       String
  user1         User     @relation("KonvUser1", fields: [user1Id], references: [id])
  user2         User     @relation("KonvUser2", fields: [user2Id], references: [id])
  poruke        Poruka[]
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([user1Id, user2Id])
  @@index([user1Id, lastMessageAt(sort: Desc)])
  @@index([user2Id, lastMessageAt(sort: Desc)])
}

model Poruka {
  id             String       @id @default(uuid())
  konverzacijaId String
  konverzacija   Konverzacija @relation(fields: [konverzacijaId], references: [id])
  posiljacId     String
  posiljac       User         @relation("PorukePostavljene", fields: [posiljacId], references: [id])
  tekst          String
  procitana      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([konverzacijaId, createdAt])
}

// ─── Politika privatnosti — verzionisanje i pristanci ────────────────────────

model PolitikaVerzija {
  id          String                @id @default(uuid())
  verzija     String                @unique  // npr. "1.0", "1.1"
  naslov      String
  efektivnaOd DateTime
  kreirao     String                // adminId
  createdAt   DateTime              @default(now())
  pristanci   PolitikaPrihvatanje[]
}

model PolitikaPrihvatanje {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  verzijaId String
  verzija   PolitikaVerzija @relation(fields: [verzijaId], references: [id])
  prihvacen Boolean         @default(true)
  createdAt DateTime        @default(now())

  @@unique([userId, verzijaId])
  @@index([userId])
}

// ─── Verzionisanje Pravilnika (paralelno sa Politikom, v3.7.0) ───────────────

model PravilnikVerzija {
  id          String                 @id @default(uuid())
  verzija     String                 @unique  // npr. "3.7.0"
  naslov      String
  efektivnaOd DateTime
  kreirao     String                 // adminId
  createdAt   DateTime               @default(now())
  pristanci   PravilnikPrihvatanje[]
}

model PravilnikPrihvatanje {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  verzijaId String
  verzija   PravilnikVerzija @relation(fields: [verzijaId], references: [id])
  prihvacen Boolean          @default(true)
  createdAt DateTime         @default(now())

  @@unique([userId, verzijaId])
  @@index([userId])
}

// ─── Osnivacki doprinos (Pravilnik o osnivackom doprinosu v3.7.0) ────────────

model OsnivackiKanal {
  id                 String   @id @default("singleton")
  ukupnoEvidentirano Int      @default(0)        // ukupno POEN-a evidentirano kroz kanal (max 2.400.000)
  brojKoraka         Int      @default(0)        // broj izvrsenih koraka (max 120)
  zatvoren           Boolean  @default(false)    // postaje true kad brojKoraka = 120
  zatvorenAt         DateTime?
  poslednjiPrag      Int      @default(0)        // posljednji aktiviran prag (100.000, 200.000, ...)
  osnivaciZakljucani Boolean  @default(false)    // admin zakljucao listu (uslov: zbir udela = 1); emisija ide samo kad je zakljucano
  osnivaciZakljucaniAt DateTime?
  updatedAt          DateTime @updatedAt
}

model Osnivac {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation("Osnivac", fields: [userId], references: [id])
  udeoBrojilac  Int                              // npr. 50 (znaci 50/zbir)
  udeoImenilac  Int                              // npr. 100 (znaci 50/100 = 50%)
  redniBroj     Int      @unique                 // redosled u javnom registru
  napomena      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  emisije       OsnivackiKorakEmisija[]
}

model OsnivackiKorakLog {
  id                  String   @id @default(uuid())
  brojKoraka          Int      @unique           // 1, 2, ..., 120
  prag                Int                        // POEN prag koji je aktivirao korak (100k, 200k, ...)
  ukupanPoenUSistemu  Int                        // total POEN-a u sistemu u trenutku okidanja
  iznosKoraka         Int      @default(20000)   // 20.000 POEN po koraku
  createdAt           DateTime @default(now())
  emisije             OsnivackiKorakEmisija[]
}

model OsnivackiKorakEmisija {
  id           String            @id @default(uuid())
  korakLogId   String
  korakLog     OsnivackiKorakLog @relation(fields: [korakLogId], references: [id])
  osnivacId    String
  osnivac      Osnivac           @relation(fields: [osnivacId], references: [id])
  iznosPoen    Int                                // emitovano ovom osnivacu u ovom koraku
  transactionId String?                           // veza na Transaction
  createdAt    DateTime          @default(now())

  @@unique([korakLogId, osnivacId])
}

// ─── Fondacija — transparentnost sredstava i Zastitni veto (cl. 71) ──────────

enum FondacijaTrosakKategorija {
  PLATA
  INFRASTRUKTURA   // hosting, domeni, serveri
  PRAVNI_TROSAK    // advokati, sudski vestaci, registracije
  SOFTWARE         // pretplate na alate, licence
  ADMINISTRATIVNO  // bankarski troskovi, pisarnica, materijal
  OPERATIVNO       // ostali operativni troskovi
  DRUGO
}

model FondacijaTrosak {
  id           String                    @id @default(uuid())
  datum        DateTime                  @db.Date
  iznosRSD     Decimal                   @db.Decimal(12, 2)
  kategorija   FondacijaTrosakKategorija
  opis         String
  dokumentUrl  String?                   // link na racun/ugovor (opciono)
  kreiraoId    String
  kreirao      User                      @relation("KreiraoTrosak", fields: [kreiraoId], references: [id])
  createdAt    DateTime                  @default(now())

  @@index([datum])
  @@index([kategorija, datum])
}

model SistemskiVeto {
  id              String    @id @default("singleton")
  aktivan         Boolean   @default(false)     // true kad Protokol < -1M I trajnoUgasen = false
  trajnoUgasen    Boolean   @default(false)     // jednosmerni flag (cl. 71)
  datumAktivacije DateTime?
  datumGasenja    DateTime?                     // kada je trajnoUgasen postao true
  updatedAt       DateTime  @updatedAt
}

// ─── Prigovor na automatizovanu odluku ───────────────────────────────────────

enum PrigovorStatus {
  PENDING
  U_OBRADI
  RESENO
  ODBIJENO
}

model PrigovorNaOdluku {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  opis         String
  tipOdluke    String         // "VERIFIKACIJA" | "SUSPENZIJA" | "PROGRAM" | "OSTALO"
  status       PrigovorStatus @default(PENDING)
  odgovor      String?
  odgovorioId  String?
  odgovorioAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
}

// ─── Blog (Vesti Fondacije) ──────────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  content     String
  authorId    String
  author      User     @relation("BlogAutor", fields: [authorId], references: [id])
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt(sort: Desc)])
}

// ─── Chat soba (globalna) ────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("ChatPoruke", fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

// ─── Dokaz stvarnosti — graf verifikacija (Pravilnik v3.5.0) ─────────────────

model VerifikacionaVeza {
  id              String    @id @default(uuid())
  verifikatorId   String
  verifikator     User      @relation("Verifikator", fields: [verifikatorId], references: [id])
  redniBroj       Int
  verifikovaniId  String
  verifikovani    User      @relation("Verifikovani", fields: [verifikovaniId], references: [id])
  vremenskiZig    DateTime  @default(now())
  // Slobodna oznaka (nadimak) koju verifikator dodeljuje verifikovanome — da bi lakše
  // pratio koga je verifikovao. NIJE javna: vidljiva samo verifikatoru i UO Fondacije
  // (admin). Ne objavljuje se drugim korisnicima i ne kači se na javnu evidenciju
  // doprinosa (Pravilnik o dokazu stvarnosti, dopuna 3.9.1; čl. 31).
  oznakaVerifikatora String?
  nadzornikId     String?
  nadzornik       User?     @relation("Nadzornik", fields: [nadzornikId], references: [id])
  podlezeNadzoru  Boolean
  nadzoranAt      DateTime?

  @@unique([verifikatorId, redniBroj])
  // K6: isti verifikator ne sme dvaput da verifikuje istog korisnika (anti-inflacija
  // indeksa + zatvara race na anti-cirkularnoj proveri kod recipročnih/duplih veza).
  @@unique([verifikatorId, verifikovaniId])
  @@index([verifikatorId])
  @@index([verifikovaniId])
  @@index([nadzornikId])
}

// ─── Zabranjena zona verifikacije (dokaz stvarnosti 3.9.2, čl. 12) ───────────
// Materijalizovana simetrična zabranjena zona: red (userId, forbiddenUserId)
// znači da userId NE SME da verifikuje forbiddenUserId (provera ide u OBA smera,
// čl. 12: "...niti korisnika u čijoj se zabranjenoj zoni sam nalazi").
// Ovo je KEŠ — izvor istine je tabela VerifikacionaVeza; celokupno stanje se
// deterministički izvodi iz grafa funkcijom recomputeZones (src/lib/protokol/zona.ts)
// i sinhronizuje u istoj transakciji sa svakim upisom, poništavanjem ili
// prestankom statusa. Skup je monoton pri upisu (unije), a pri poništavanju se
// NE oduzima inkrementalno (unija nije invertibilna) nego preračunava od nule.
model VerifikacionaZona {
  userId          String
  user            User   @relation("ZonaVlasnik", fields: [userId], references: [id], onDelete: Cascade)
  forbiddenUserId String
  forbiddenUser   User   @relation("ZonaZabranjeni", fields: [forbiddenUserId], references: [id], onDelete: Cascade)

  @@id([userId, forbiddenUserId])
  @@index([forbiddenUserId])
  @@map("verification_zone")
}

model VerifikacijaToken {
  id         String    @id @default(uuid())
  token      String    @unique
  brojCifara String    @unique
  korisnikId String
  korisnik   User      @relation(fields: [korisnikId], references: [id])
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  used       Boolean   @default(false)
  usedAt     DateTime?

  @@index([korisnikId])
  @@index([expiresAt])
}

// ─── Tabla zahteva za jemstvo ─────────────────────────────────────────────────
// Neverifikovan korisnik se predstavlja mreži verifikovanih radi uspostavljanja
// kontakta neophodnog za verifikaciju (čl. 32 Pravilnika, čl. 16 Uslova korišćenja).
// Tekst je vidljiv svim prijavljenima; kontakt samo verifikovanima, uz logovanje.

enum JemstvoStatus {
  AKTIVAN
  POVUCEN
  ISTEKAO
  UKLONJEN
  ZAVRSEN
}

model ZahtevZaJemstvo {
  id                  String        @id @default(uuid())
  userId              String
  user                User          @relation(fields: [userId], references: [id])
  tekstPredstavljanja String
  kontaktPodaci       String
  status              JemstvoStatus @default(AKTIVAN)
  uklonjenRazlog      String?
  createdAt           DateTime      @default(now())
  expiresAt           DateTime

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

// ─── Nadzor integriteta verifikacija (anti-malverzacija, 1. krug) ─────────────
// Noćni cron (/api/cron/nadzor-integriteta) računa pravila P1–P15 nad grafom
// verifikacija i tokom POEN-a i upisuje OBELEŽENE naloge/grupe ovde. Sistem
// NIKAD sam ne preduzima radnju — samo evidentira i (za HITNO) javi superadminu;
// gašenje uvek povlači čovek. `subjektId` je plain string (bez FK na User) da
// model ostane labavo spregnut. Status CISTO = superadmin odbacio kao lažnu uzbunu.
model RizikNalaz {
  id         String    @id @default(uuid())
  tip        String    // "NALOG" | "GRUPA"
  subjektId  String?   // userId za NALOG; null za GRUPA
  pseudonim  String?   // za prikaz (NALOG)
  clanovi    String?   // JSON [{id,pseudonim}] za GRUPA
  pravila    String    // JSON [{kod,nivo,opis}]
  rizik      Int       // ukupan skor (zbir težina pravila)
  nivo       String    // najviši nivo: "INFO" | "UPOZORENJE" | "HITNO"
  status     String    @default("OTVOREN") // "OTVOREN" | "CISTO"
  resenById  String?
  resenAt    DateTime?
  createdAt  DateTime  @default(now())

  @@index([status, rizik(sort: Desc)])
  @@index([subjektId])
}

// ─── Prijava bagova (greške na platformi) ─────────────────────────────────────
// Bilo koji prijavljen korisnik može da prijavi bag (grešku). Lista svih prijava
// je javna (vidljiva svim prijavljenima) zajedno sa statusom — da svako vidi šta
// je prijavljeno i da li se na tome radi. Status menja admin.

enum BugStatus {
  PRIJAVLJEN  // prijavljeno, još se ne radi
  U_RADU      // radi se na tome
  RESENO      // ispravljeno
  ODBIJENO    // nije bag / neće se raditi
}

model Bug {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation("PrijaviocBaga", fields: [userId], references: [id])
  naslov    String
  opis      String
  status    BugStatus @default(PRIJAVLJEN)
  odgovor   String?   // beleška/odgovor admina (npr. zašto je odbijeno ili kad je rešeno)
  resenoAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
}
