generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enumi ───────────────────────────────────────────────────────────────────

enum Role {
  FIZICKO_LICE
  CLAN_KRUGA
  ADMIN
}

enum WalletType {
  USER
  KRUG
  PROTOKOL
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KrugStatus {
  ACTIVE
  SUSPENDED
}

enum KrugOsnivanjeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PristupnicaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectType {
  PRIKUPLJANJE
  REDISTRIBUCIJA
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
}

enum TransactionType {
  TRANSFER
  EMISIJA_VERIFIKACIJA
  EMISIJA_NADZOR
  EMISIJA_PREPORUKA
  EMISIJA_DONACIJA
  EMISIJA_POKROVITELJ
  EMISIJA_KRUG_OSNIVANJE
  EMISIJA_KRUG_BONUS
  EMISIJA_PROGRAM
  UPIS_ZRNO
  OTPIS_ZRNO
  EMISIJA_OSNIVACKI
}

enum TipKorisnika {
  POCETNI
  REGULARNI
  NOSILAC_ZRNA
  NEVERIFIKOVAN
}

enum ZrnoZahtevStatus {
  PENDING
  EXECUTED
  CANCELLED
}

enum ZrnoStatusAkcija {
  ZAKLJUCAJ
  OTKLJUCAJ
}

enum PredlogStatus {
  ACTIVE
  CLOSED
}

enum ProgramType {
  PED
  PODRSKA_MAJKAMA
  PODRSKA_STARIJIMA
  POSEBNA_BRIGA
  SKOLOVANJE
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  EXCLUDED
}

enum DonationStatus {
  PENDING
  CONFIRMED
}

enum PokroviteljDoprinosTip {
  SPONZORSTVO_KRUGA
  DONACIJA_FONDACIJI
}

enum ZadatakStatus {
  OTVOREN
  U_IZVRSENJU
  IZVRSEN
  NEIZVRSEN
  POVUCEN
}

enum ZadatakMod {
  PO_SATU
  U_CELOSTI
}

enum ZadatakIzvor {
  FONDACIJA
  KRUG
  PROJEKAT
}

enum PrijavaStatus {
  PODNETA
  PRIMLJENA
  ODBIJENA
  ODUSTAO
}

enum IzvrsenjeStatus {
  PODNETO
  POTVRDJENO
  USLOVNO
  ODBIJENO
  EVIDENTIRANO
}

// ─── Modeli ───────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  email              String?   @unique
  passwordHash       String?
  oauthProvider      String?
  oauthId            String?
  oauthPending       Boolean   @default(false)
  pseudonim          String    @unique
  role               Role       @default(FIZICKO_LICE)
  status             UserStatus @default(ACTIVE)
  suspendedAt        DateTime?
  suspendedReason    String?
  verified           Boolean   @default(false)
  verifiedAt         DateTime?
  tipKorisnika           TipKorisnika @default(NEVERIFIKOVAN)
  indeksStvarnosti       Int          @default(0)
  slotoviPotroseni       Int          @default(0)
  pocetnaEmisijaIzvrsena Boolean      @default(false)
  pseudonimChangedAt DateTime?
  referralCode       String    @unique
  memberHash         String    @unique
  location           String?
  telefon            String?
  avatar             String?
  deaktiviranAt      DateTime?
  pristankiPolitike  PolitikaPrihvatanje[]
  pristankiPravilnika PravilnikPrihvatanje[]
  osnivacZapis        Osnivac?                   @relation("Osnivac")
  kreiraniTroskovi    FondacijaTrosak[]          @relation("KreiraoTrosak")
  referredById       String?
  referredBy         User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals          User[]    @relation("Referrals")
  wallet             Wallet?
  referralsMade      Referral[] @relation("Referrer")
  referralReceived   Referral?  @relation("Referred")
  podaci                 UserPodaci?
  donations              DonationRecord[]
  kreiraniPokrovitelji   Pokrovitelj[]              @relation("AdminKreiraoP")
  vlasnikPokrovitelja    Pokrovitelj[]              @relation("VlasnikP")
  evidentiraniDoprinosi  PokroviteljDoprinos[]      @relation("EvidentiraoDoprinos")
  pokroviteljBonusi      PokroviteljBonusEmisija[]  @relation("PrimalacBonusa")
  kreiraniZadaci         Zadatak[]                  @relation("ZadaciKreirani")
  zadatakPrijave         ZadatakPrijava[]           @relation("ZadatakPrijave")
  zadatakIzvrsenja       ZadatakIzvrsenje[]         @relation("ZadatakIzvrsenja")
  verificationRequest    VerificationRequest?
  listings               MarketplaceListing[]       @relation("SellerListings")
  purchases              MarketplaceListing[]       @relation("BuyerListings")
  krugClanstva   KrugClanstvo[]
  pristupnice            KrugPristupnica[]
  osnivanjeZahtevi       KrugOsnivanjeZahtev[] @relation("Inicijator")
  programEnrollments     ProgramEnrollment[]
  zrnoStanje             ZrnoStanje?
  zrnoUpisZahtevi        ZrnoUpisZahtev[]
  zrnoOtpisZahtevi       ZrnoOtpisZahtev[]
  zrnoStatusZahtevi      ZrnoStatusZahtev[]
  delegiraoKome          ZrnoDelegacija?            @relation("Delegator")
  delegatZa              ZrnoDelegacija[]           @relation("Delegat")
  kreiraniPredlozi       GlasanjePredlog[]
  glasovi                GlasanjeGlas[]
  auditLogs              AuditLog[]                 @relation("AdminActions")
  notifikacije           Notifikacija[]
  konverzacije1          Konverzacija[]             @relation("KonvUser1")
  konverzacije2          Konverzacija[]             @relation("KonvUser2")
  porukePoslate          Poruka[]                   @relation("PorukePostavljene")
  prigovori              PrigovorNaOdluku[]
  blogObjave             BlogPost[]                 @relation("BlogAutor")
  chatPoruke             ChatMessage[]              @relation("ChatPoruke")
  passwordResetTokens    PasswordResetToken[]
  verifikacijeKojeSamObavio       VerifikacionaVeza[] @relation("Verifikator")
  verifikacijaKojomSamVerifikovan VerifikacionaVeza?  @relation("Verifikovani")
  nadzori                         VerifikacionaVeza[] @relation("Nadzornik")
  verifikacijaTokeni              VerifikacijaToken[]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model UserPodaci {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  punoIme   String?
  opis      String?
  updatedAt DateTime @updatedAt

  // Vidljivost profila
  prikaziLokaciju      Boolean @default(true)
  prikaziOpis          Boolean @default(false)
  prikaziPunoIme       Boolean @default(false)
  prikaziTelefon       Boolean @default(false)
  prikaziBilans        Boolean @default(true)
  prikaziZrno          Boolean @default(true)
  prikaziRangPreporuka Boolean @default(true)
  prikaziRangDonacija  Boolean @default(true)
  prikaziOglase        Boolean @default(true)
}

model Wallet {
  id          String        @id @default(uuid())
  userId      String?       @unique
  user        User?         @relation(fields: [userId], references: [id])
  krugId String?       @unique
  krug   Krug?    @relation("KrugWallet", fields: [krugId], references: [id])
  balance     Int           @default(0)
  type        WalletType
  outgoingTx  Transaction[] @relation("FromWallet")
  incomingTx  Transaction[] @relation("ToWallet")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Transaction {
  id           String          @id @default(uuid())
  fromWalletId String?
  fromWallet   Wallet?         @relation("FromWallet", fields: [fromWalletId], references: [id])
  toWalletId   String
  toWallet     Wallet          @relation("ToWallet", fields: [toWalletId], references: [id])
  amount       Int
  type         TransactionType
  description  String?
  createdAt    DateTime        @default(now())
}

model Referral {
  id           String   @id @default(uuid())
  referrerId   String
  referrer     User     @relation("Referrer", fields: [referrerId], references: [id])
  referredId   String   @unique
  referred     User     @relation("Referred", fields: [referredId], references: [id])
  rewardPaid   Boolean  @default(false)
  rewardAmount Int?
  createdAt    DateTime @default(now())
}

model VerificationRequest {
  id               String             @id @default(uuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id])
  jmbg             String
  idFrontPath      String?            // base64 slika prednje strane LK
  idBackPath       String?            // base64 slika zadnje strane LK
  kanal            String?            // "UPLOAD" | "LICNO"
  status           VerificationStatus @default(PENDING)
  rejectionReason  String?
  reviewedAt       DateTime?
  reviewedById     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Krug {
  id             String          @id @default(uuid())
  name           String          @unique
  description    String?
  location       String?
  status         KrugStatus @default(ACTIVE)
  wallet         Wallet?         @relation("KrugWallet")
  memberships    KrugClanstvo[]
  pristupnice    KrugPristupnica[]
  projects       KrugProjekat[]
  bonusLogs      KrugBonusLog[]
  zadaci         Zadatak[]       @relation("KrugZadaci")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model KrugClanstvo {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  krugId String
  krug   Krug @relation(fields: [krugId], references: [id])
  isAdmin     Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  @@index([userId, leftAt])
  @@index([krugId, leftAt])
}

model KrugOsnivanjeZahtev {
  id              String                   @id @default(uuid())
  name            String
  description     String?
  location        String?
  inicijatorId    String
  inicijator      User                     @relation("Inicijator", fields: [inicijatorId], references: [id])
  osnivaci        String[]
  status          KrugOsnivanjeStatus @default(PENDING)
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime                 @default(now())
}

model KrugPristupnica {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  krugId String
  krug   Krug         @relation(fields: [krugId], references: [id])
  status      PristupnicaStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  @@unique([userId, krugId])
}

model KrugProjekat {
  id          String      @id @default(uuid())
  krugId String
  krug   Krug   @relation(fields: [krugId], references: [id])
  type        ProjectType
  title       String
  description String
  status      String      @default("ACTIVE")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model KrugBonusLog {
  id          String    @id @default(uuid())
  krugId String
  krug   Krug @relation(fields: [krugId], references: [id])
  threshold   Int
  amount      Int
  createdAt   DateTime  @default(now())
}

model MarketplaceListing {
  id          String        @id @default(uuid())
  sellerId    String
  seller      User          @relation("SellerListings", fields: [sellerId], references: [id])
  buyerId     String?
  buyer       User?         @relation("BuyerListings", fields: [buyerId], references: [id])
  title       String
  description String
  price       Int
  category    String
  images      String[]
  location    String?
  phone       String?
  status      ListingStatus @default(ACTIVE)
  soldAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, category, createdAt])
}

model ProtokolProgram {
  type        ProgramType @id
  isActive    Boolean     @default(false)
  activatedAt DateTime?
  updatedAt   DateTime    @updatedAt
}

model ProgramEnrollment {
  id                 String               @id @default(uuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id])
  type               ProgramType
  status             EnrollmentStatus     @default(PENDING)
  metadata           Json?
  dailyAmount        Int?
  approvedById       String?
  approvedAt         DateTime?
  rejectionReason    String?
  nextReverifikacija DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([userId, type])
  @@index([status, type])
}

model DailyEmissionSummary {
  id             String   @id @default(uuid())
  date           DateTime @db.Date @unique
  opticaj        Int
  limit          Int
  totalRequested Int
  totalEmitted   Int
  koeficijent    Decimal  @db.Decimal(10, 6)
  breakdown      Json
  createdAt      DateTime @default(now())
}

// ─── Operativni doprinos — Zadaci za zajedničko dobro (Pravilnik o operativnom doprinosu v3.7.0) ───

model Zadatak {
  id             String        @id @default(uuid())
  naslov         String
  opis           String
  cilj           String        // doprinos zajedničkom dobru (čl. 5)
  kriterijumi    String        // kriterijumi izvršenja (čl. 5)
  izvor          ZadatakIzvor  @default(FONDACIJA)

  mod            ZadatakMod                    // PO_SATU | U_CELOSTI
  stopaPoSatu    Int?          // PO_SATU: 1000–2500 POEN/sat
  maxSati        Int?          // PO_SATU: gornji limit sati za izvršenje
  iznosUCelosti  Int?          // U_CELOSTI: fiksni predloženi POEN
  gornjaGranica  Int?          // čl. 26 — gornja granica predloženog POEN po zadatku
  predlozeniPoen Int           // procena ukupnog predloženog POEN (čl. 5/6), za prikaz

  brojIzvrsilaca Int           @default(1)
  minIndeks      Int           @default(10)    // čl. 9 — minimalni indeks stvarnosti
  saOdobravanjem Boolean       @default(false) // čl. 14
  kvalFilter     String?       // opcioni kvalifikacioni filter (čl. 9 st. 3)

  rokPrijave     DateTime?
  rokIzvrsenja   DateTime?
  status         ZadatakStatus @default(OTVOREN)

  createdById    String
  createdBy      User          @relation("ZadaciKreirani", fields: [createdById], references: [id])
  krugId         String?
  krug           Krug?         @relation("KrugZadaci", fields: [krugId], references: [id])

  prijave        ZadatakPrijava[]
  izvrsenja      ZadatakIzvrsenje[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, createdAt(sort: Desc)])
}

model ZadatakPrijava {
  id             String         @id @default(uuid())
  zadatakId      String
  zadatak        Zadatak        @relation(fields: [zadatakId], references: [id])
  userId         String
  user           User           @relation("ZadatakPrijave", fields: [userId], references: [id])

  planIzvrsenja  String         // opis načina + način dokazivanja (čl. 11)
  status         PrijavaStatus  @default(PRIMLJENA) // PODNETA ako zadatak ima saOdobravanjem
  verifikatorId  String?        // ko je odobrio plan (čl. 14)
  primljenaAt    DateTime?
  odbijenaRazlog String?

  izvrsenja      ZadatakIzvrsenje[]
  createdAt      DateTime       @default(now())

  @@unique([zadatakId, userId])
  @@index([status, zadatakId])
}

model ZadatakIzvrsenje {
  id               String          @id @default(uuid())
  prijavaId        String
  prijava          ZadatakPrijava  @relation(fields: [prijavaId], references: [id])
  zadatakId        String
  zadatak          Zadatak         @relation(fields: [zadatakId], references: [id])
  userId           String
  user             User            @relation("ZadatakIzvrsenja", fields: [userId], references: [id])

  datum            DateTime        @db.Date
  sati             Int?            // PO_SATU
  dokaz            String          // foto/izveštaj/link (čl. 11/18)
  tezina           Int             // sati×stopaPoSatu ILI iznosUCelosti — težina u raspodeli
  zavrsno          Boolean         @default(true)  // za sad svako izvršenje je završno (jednodnevni)
  status           IzvrsenjeStatus @default(PODNETO)
  verifikatorId    String?
  potvrdjenaAt     DateTime?
  obrazlozenje     String?         // za USLOVNO/ODBIJENO
  evidentiraniPoen Int?            // popunjava noćna raspodela
  createdAt        DateTime        @default(now())

  @@unique([prijavaId, datum])
  @@index([datum, status])
}

// ─── ZRNO sistem ─────────────────────────────────────────────────────────────

model ZrnoTrziste {
  id          String    @id @default("singleton")
  isActive    Boolean   @default(false)
  activatedAt DateTime?
  updatedAt   DateTime  @updatedAt
}

model ZrnoStanje {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  slobodno  Int      @default(0)
  aktivno   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model ZrnoUpisZahtev {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  poenIznos    Int
  date         DateTime         @db.Date
  status       ZrnoZahtevStatus @default(PENDING)
  zrnaKupljeno Int?
  poenPlaceno  Int?
  createdAt    DateTime         @default(now())

  @@unique([userId, date])
  @@index([date, status])
}

model ZrnoOtpisZahtev {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  kolicina     Int
  date         DateTime         @db.Date
  status       ZrnoZahtevStatus @default(PENDING)
  poenDobijeno Int?
  createdAt    DateTime         @default(now())

  @@unique([userId, date])
  @@index([date, status])
}

model ZrnoStatusZahtev {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  kolicina  Int
  akcija    ZrnoStatusAkcija
  date      DateTime         @db.Date
  status    ZrnoZahtevStatus @default(PENDING)
  createdAt DateTime         @default(now())

  @@index([date, status])
}

model ZrnoDailyRate {
  date           DateTime @db.Date @unique
  kurs           Decimal  @db.Decimal(20, 2)
  protokolMinus  Int
  zrnaUProtokolu Int
  createdAt      DateTime @default(now())
}

model ZrnoDelegacija {
  id          String   @id @default(uuid())
  delegatorId String   @unique
  delegator   User     @relation("Delegator", fields: [delegatorId], references: [id])
  delegatId   String
  delegat     User     @relation("Delegat", fields: [delegatId], references: [id])
  aktivna     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── Glasanje ─────────────────────────────────────────────────────────────────

model GlasanjePredlog {
  id          String        @id @default(uuid())
  title       String
  description String
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  deadline    DateTime
  status      PredlogStatus @default(ACTIVE)
  glasovi     GlasanjeGlas[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GlasanjeGlas {
  id              String          @id @default(uuid())
  predlogId       String
  predlog         GlasanjePredlog @relation(fields: [predlogId], references: [id])
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  za              Boolean
  glasackaGlasova Int
  createdAt       DateTime        @default(now())

  @@unique([predlogId, userId])
  @@index([predlogId])
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String
  admin     User     @relation("AdminActions", fields: [adminId], references: [id])
  akcija    String
  targetId  String?
  detalji   String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model DonationRecord {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  amountRSD       Decimal        @db.Decimal(12, 2)
  cumulativeRSD   Decimal        @db.Decimal(12, 2)
  level           Int
  poenEmitted     Int
  status          DonationStatus @default(PENDING)
  referenceNumber String?
  confirmedAt     DateTime?
  confirmedById   String?
  createdAt       DateTime       @default(now())

  @@index([status, createdAt])
}

// ─── Pokrovitelji ─────────────────────────────────────────────────────────────

model Pokrovitelj {
  id             String      @id @default(uuid())
  naziv          String
  pib            String      @unique
  adresa         String?
  kontaktEmail   String?
  kontaktTelefon String?
  vlasnikId      String
  vlasnik        User        @relation("VlasnikP", fields: [vlasnikId], references: [id])
  kreiraoId      String
  kreirao        User        @relation("AdminKreiraoP", fields: [kreiraoId], references: [id])
  rsdKumulativ   Decimal     @default(0) @db.Decimal(12, 2)
  trenutniNivo   Int         @default(0)
  status         String      @default("ACTIVE")  // ACTIVE | SUSPENDED
  doprinosi      PokroviteljDoprinos[]
  bonusiEmisije  PokroviteljBonusEmisija[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([vlasnikId])
  @@index([status])
}

model PokroviteljDoprinos {
  id            String                  @id @default(uuid())
  pokroviteljId String
  pokrovitelj   Pokrovitelj             @relation(fields: [pokroviteljId], references: [id])
  rsdIznos      Decimal                 @db.Decimal(12, 2)
  tip           PokroviteljDoprinosTip
  evidentiraoId String
  evidentirao   User                    @relation("EvidentiraoDoprinos", fields: [evidentiraoId], references: [id])
  napomena      String?
  createdAt     DateTime                @default(now())

  @@index([pokroviteljId, createdAt(sort: Desc)])
}

model PokroviteljBonusEmisija {
  id            String      @id @default(uuid())
  pokroviteljId String
  pokrovitelj   Pokrovitelj @relation(fields: [pokroviteljId], references: [id])
  vlasnikId     String
  vlasnik       User        @relation("PrimalacBonusa", fields: [vlasnikId], references: [id])
  nivo          Int
  bonusPoen     Int
  transactionId String?
  createdAt     DateTime    @default(now())

  @@index([pokroviteljId])
  @@index([vlasnikId])
}

model Notifikacija {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tip       String
  naslov    String
  tekst     String
  procitana Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, procitana])
  @@index([userId, createdAt(sort: Desc)])
}

model Konverzacija {
  id            String   @id @default(uuid())
  user1Id       String
  user2Id       String
  user1         User     @relation("KonvUser1", fields: [user1Id], references: [id])
  user2         User     @relation("KonvUser2", fields: [user2Id], references: [id])
  poruke        Poruka[]
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([user1Id, user2Id])
  @@index([user1Id, lastMessageAt(sort: Desc)])
  @@index([user2Id, lastMessageAt(sort: Desc)])
}

model Poruka {
  id             String       @id @default(uuid())
  konverzacijaId String
  konverzacija   Konverzacija @relation(fields: [konverzacijaId], references: [id])
  posiljacId     String
  posiljac       User         @relation("PorukePostavljene", fields: [posiljacId], references: [id])
  tekst          String
  procitana      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([konverzacijaId, createdAt])
}

// ─── Politika privatnosti — verzionisanje i pristanci ────────────────────────

model PolitikaVerzija {
  id          String                @id @default(uuid())
  verzija     String                @unique  // npr. "1.0", "1.1"
  naslov      String
  efektivnaOd DateTime
  kreirao     String                // adminId
  createdAt   DateTime              @default(now())
  pristanci   PolitikaPrihvatanje[]
}

model PolitikaPrihvatanje {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  verzijaId String
  verzija   PolitikaVerzija @relation(fields: [verzijaId], references: [id])
  prihvacen Boolean         @default(true)
  createdAt DateTime        @default(now())

  @@unique([userId, verzijaId])
  @@index([userId])
}

// ─── Verzionisanje Pravilnika (paralelno sa Politikom, v3.7.0) ───────────────

model PravilnikVerzija {
  id          String                 @id @default(uuid())
  verzija     String                 @unique  // npr. "3.7.0"
  naslov      String
  efektivnaOd DateTime
  kreirao     String                 // adminId
  createdAt   DateTime               @default(now())
  pristanci   PravilnikPrihvatanje[]
}

model PravilnikPrihvatanje {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  verzijaId String
  verzija   PravilnikVerzija @relation(fields: [verzijaId], references: [id])
  prihvacen Boolean          @default(true)
  createdAt DateTime         @default(now())

  @@unique([userId, verzijaId])
  @@index([userId])
}

// ─── Osnivacki doprinos (Pravilnik o osnivackom doprinosu v3.7.0) ────────────

model OsnivackiKanal {
  id                 String   @id @default("singleton")
  ukupnoEvidentirano Int      @default(0)        // ukupno POEN-a evidentirano kroz kanal (max 2.400.000)
  brojKoraka         Int      @default(0)        // broj izvrsenih koraka (max 120)
  zatvoren           Boolean  @default(false)    // postaje true kad brojKoraka = 120
  zatvorenAt         DateTime?
  poslednjiPrag      Int      @default(0)        // posljednji aktiviran prag (100.000, 200.000, ...)
  updatedAt          DateTime @updatedAt
}

model Osnivac {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation("Osnivac", fields: [userId], references: [id])
  udeoBrojilac  Int                              // npr. 50 (znaci 50/zbir)
  udeoImenilac  Int                              // npr. 100 (znaci 50/100 = 50%)
  redniBroj     Int      @unique                 // redosled u javnom registru
  napomena      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  emisije       OsnivackiKorakEmisija[]
}

model OsnivackiKorakLog {
  id                  String   @id @default(uuid())
  brojKoraka          Int      @unique           // 1, 2, ..., 120
  prag                Int                        // POEN prag koji je aktivirao korak (100k, 200k, ...)
  ukupanPoenUSistemu  Int                        // total POEN-a u sistemu u trenutku okidanja
  iznosKoraka         Int      @default(20000)   // 20.000 POEN po koraku
  createdAt           DateTime @default(now())
  emisije             OsnivackiKorakEmisija[]
}

model OsnivackiKorakEmisija {
  id           String            @id @default(uuid())
  korakLogId   String
  korakLog     OsnivackiKorakLog @relation(fields: [korakLogId], references: [id])
  osnivacId    String
  osnivac      Osnivac           @relation(fields: [osnivacId], references: [id])
  iznosPoen    Int                                // emitovano ovom osnivacu u ovom koraku
  transactionId String?                           // veza na Transaction
  createdAt    DateTime          @default(now())

  @@unique([korakLogId, osnivacId])
}

// ─── Fondacija — transparentnost sredstava i Zastitni veto (cl. 71) ──────────

enum FondacijaTrosakKategorija {
  PLATA
  INFRASTRUKTURA   // hosting, domeni, serveri
  PRAVNI_TROSAK    // advokati, sudski vestaci, registracije
  SOFTWARE         // pretplate na alate, licence
  ADMINISTRATIVNO  // bankarski troskovi, pisarnica, materijal
  OPERATIVNO       // ostali operativni troskovi
  DRUGO
}

model FondacijaTrosak {
  id           String                    @id @default(uuid())
  datum        DateTime                  @db.Date
  iznosRSD     Decimal                   @db.Decimal(12, 2)
  kategorija   FondacijaTrosakKategorija
  opis         String
  dokumentUrl  String?                   // link na racun/ugovor (opciono)
  kreiraoId    String
  kreirao      User                      @relation("KreiraoTrosak", fields: [kreiraoId], references: [id])
  createdAt    DateTime                  @default(now())

  @@index([datum])
  @@index([kategorija, datum])
}

model SistemskiVeto {
  id              String    @id @default("singleton")
  aktivan         Boolean   @default(false)     // true kad Protokol < -1M I trajnoUgasen = false
  trajnoUgasen    Boolean   @default(false)     // jednosmerni flag (cl. 71)
  datumAktivacije DateTime?
  datumGasenja    DateTime?                     // kada je trajnoUgasen postao true
  updatedAt       DateTime  @updatedAt
}

// ─── Verifikacija — odvojeni pristanak za obradu lk/JMBG ─────────────────────

model VerifikacijaPristanak {
  id          String   @id @default(uuid())
  userId      String   @unique
  prihvacenAt DateTime @default(now())
  ipAdresa    String?
  userAgent   String?
}

// ─── Prigovor na automatizovanu odluku ───────────────────────────────────────

enum PrigovorStatus {
  PENDING
  U_OBRADI
  RESENO
  ODBIJENO
}

model PrigovorNaOdluku {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  opis         String
  tipOdluke    String         // "VERIFIKACIJA" | "SUSPENZIJA" | "PROGRAM" | "OSTALO"
  status       PrigovorStatus @default(PENDING)
  odgovor      String?
  odgovorioId  String?
  odgovorioAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
}

// ─── Blog (Vesti Fondacije) ──────────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  content     String
  authorId    String
  author      User     @relation("BlogAutor", fields: [authorId], references: [id])
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt(sort: Desc)])
}

// ─── Chat soba (globalna) ────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("ChatPoruke", fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

// ─── Dokaz stvarnosti — graf verifikacija (Pravilnik v3.5.0) ─────────────────

model VerifikacionaVeza {
  id              String    @id @default(uuid())
  verifikatorId   String
  verifikator     User      @relation("Verifikator", fields: [verifikatorId], references: [id])
  redniBroj       Int
  verifikovaniId  String    @unique
  verifikovani    User      @relation("Verifikovani", fields: [verifikovaniId], references: [id])
  vremenskiZig    DateTime  @default(now())
  nadzornikId     String?
  nadzornik       User?     @relation("Nadzornik", fields: [nadzornikId], references: [id])
  podlezeNadzoru  Boolean
  nadzoranAt      DateTime?

  @@unique([verifikatorId, redniBroj])
  @@index([verifikatorId])
  @@index([verifikovaniId])
  @@index([nadzornikId])
}

model VerifikacijaToken {
  id         String    @id @default(uuid())
  token      String    @unique
  brojCifara String    @unique
  korisnikId String
  korisnik   User      @relation(fields: [korisnikId], references: [id])
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  used       Boolean   @default(false)
  usedAt     DateTime?

  @@index([korisnikId])
  @@index([expiresAt])
}
